---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Portfolio de SamuDev - Desarrollador Frontend especializado en React, Astro y diseño moderno. Transformo ideas en experiencias digitales únicas." />
		<meta name="keywords" content="desarrollador frontend, react, astro, portfolio, diseño web" />
		<meta name="author" content="SamuDev" />
		<meta property="og:title" content="SamuDev | Portfolio" />
		<meta property="og:description" content="Desarrollador Frontend especializado en React, Astro y diseño moderno." />
		<meta property="og:type" content="website" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
		<title>SamuDev | Portfolio</title>
		<script is:inline>
			try {
				const lang = localStorage.getItem("samudev-lang");
				if (lang === "en" || lang === "es") document.documentElement.lang = lang;
			} catch {}
		</script>
	</head>
	<body class="bg-surface text-white font-sans antialiased">
		<slot />
	</body>
</html>
